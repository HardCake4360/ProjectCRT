  - characterName: "\uC0B0"
    portrait: 0
    charInterval: 0
    choices: {fileID: 0}
    text: "\uACE0\uC591\uC774\uAC00 \uC0AC\uB77C\uC9C4\uAC74 \uC774 \uADFC\uCC98\uC785\uB2C8\uAE4C?"
