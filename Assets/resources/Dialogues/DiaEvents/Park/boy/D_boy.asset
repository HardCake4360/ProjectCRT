    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uADF8\uAC70 \uC798\uB410\uAD6C\uB098. \uB098\uD55C\uD14C \uBCF4\uB0B4\uC904
      \uC218 \uC788\uACA0\uB2C8?"
