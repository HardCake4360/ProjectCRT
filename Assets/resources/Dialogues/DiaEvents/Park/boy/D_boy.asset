    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uC54C\uB824\uB2EC\uB77C\uACE0\uB294 \uC548\uD558\uC154\uC11C\uC694"
  - characterName: "\uC18C\uB144"
    Portrait: 0
