    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uB204\uAD74 \uBD24\uB294\uC9C0\uB294 \uC548\uC54C\uB824\uC904\uAC70\uB2C8?"
  - characterName: "\uC18C\uB144"
