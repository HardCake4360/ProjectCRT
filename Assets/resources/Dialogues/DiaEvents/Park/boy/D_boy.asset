    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uC544\uAE4C \uC774\uC0C1\uD55C \uC544\uC800\uC528\uAC00 \uACE0\uC591\uC774\uB791
      \uC2F8\uC6B0\uACE0 \uC788\uB354\uB77C\uAD6C\uC694"
  - characterName: "\uC18C\uB144"
    Portrait: 0
    CamNumber: 0
    CharInterval: 0
    QuestionDia: {fileID: 0}
    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uC5C4\uCCAD \uC6C3\uACA8\uC11C \uC601\uC0C1\uAE4C\uC9C0 \uCC0D\uC5B4\uB1A8\uB2E4\uB2C8\uAE4C\uC694?"
