    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uADF8\uB798...\uBB50\uAC00 \uADF8\uB807\uAC8C \uC6C3\uAE30\uB098...?"
  - characterName: "\uC811\uC218\uC6D0"
    Portrait: 0
    CamNumber: 0
    CharInterval: 0
    QuestionDia: {fileID: 0}
    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uADF8\uB0E5 \uD3C9\uC18C \uACBD\uAD00\uB2D8\uC774\uB791\uC740 \uC774\uBBF8\uC9C0\uAC00
      \uC548\uB9DE\uB294 \uAC83 \uAC19\uC544\uC11C\uC694. \uD6C4\uD6D7"
  - characterName: "\uC0B0"
    Portrait: 0
    CamNumber: 0
    CharInterval: 0
    QuestionDia: {fileID: 0}
    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uBB50, \uB0B4\uAC00 \uB9E1\uACE0 \uC2F6\uC5B4\uC11C \uB9E1\uC740 \uAC83\uB3C4
      \uC544\uB2C8\uAE34 \uD55C\uB370..."
  - characterName: "\uC0B0"
    Portrait: 0
    CamNumber: 0
    CharInterval: 0
    QuestionDia: {fileID: 0}
    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uC544\uBB34\uD2BC, \uC9C0\uAE08 \uC11C\uC7A5 \uC788\uB098?"
  - characterName: "\uC811\uC218\uC6D0"
    Portrait: 0
    CamNumber: 0
    CharInterval: 0
    QuestionDia: {fileID: 0}
    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uC11C\uC7A5\uB2D8\uC740 \uC7A0\uC2DC \uB098\uAC00\uC168\uC5B4\uC694.
      \uAE09\uD55C \uC77C\uC778\uAC83 \uAC19\uB358\uB370..."
  - characterName: "\uC0B0"
    Portrait: 0
    CamNumber: 0
    CharInterval: 0
    QuestionDia: {fileID: 0}
    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uB2E4\uC74C \uC77C\uAE4C\uC9C0 \uC7A0\uC2DC \uC228\uB3CC\uB9B4 \uC2DC\uAC04\uC740
      \uC788\uACA0\uAD70"
  - characterName: "\uC0B0"
    Portrait: 0
    CamNumber: 0
    CharInterval: 0
    QuestionDia: {fileID: 0}
    OnLineStart:
      m_PersistentCalls:
        m_Calls: []
    text: "\uC77C \uC0DD\uAE30\uBA74 \uC5F0\uB77D\uC880 \uBD80\uD0C1\uD558\uB124"
  - characterName: "\uC811\uC218\uC6D0"
