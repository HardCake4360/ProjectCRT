  lines:
  - characterName: "\uC11C\uC7A5"
    portrait: 0
    charInterval: 0.05
    choices: {fileID: 0}
    text: "\uC544....\uC654\uAD70"
  - characterName: "\uC0B0"
    portrait: 0
    charInterval: 0.05
    choices: {fileID: 0}
    text: "\uADC0\uC2E0\uC774\uB77C\uB3C4 \uBCF8 \uD45C\uC815\uC73C\uB85C \uBC18\uAE30\uC9C0
      \uB9D0\uC544\uC8FC\uC2DC\uC8E0"
  - characterName: "\uC11C\uC7A5"
    portrait: 0
    charInterval: 0.05
    choices: {fileID: 0}
    text: "...\uBBF8\uC548\uD558\uB124, \uADF8\uB7FC \uBCF8\uB860\uC73C\uB85C \uB118\uC5B4\uAC00\uC9C0"
  - characterName: "\uC11C\uC7A5"
    portrait: 0
    charInterval: 0.05
    choices: {fileID: 0}
    text: "\uC624\uB298 \uAE09\uD788 \uBD80\uB974\uC9C0 \uC54A\uC558\uB098. \uC88B\uC740\uC77C\uC774
      \uC544\uB2C8\uB780\uAC74 \uB300\uCDA9 \uC9D0\uC791\uD588\uACA0\uC9C0?"
  - characterName: "\uC0B0"
    portrait: 0
    charInterval: 0.05
    choices: {fileID: 0}
    text: "\uBB50, \uD55C\uB450\uBC88 \uC785\uB2C8\uAE4C."
  - characterName: "\uC11C\uC7A5"
    portrait: 0
    charInterval: 0.05
    choices: {fileID: 0}
    text: "\uADF8\uB798, \uC544\uBB34\uD2BC...\uC774\uC81C \uB9D0\uD574\uC8FC\uACA0\uB124"
  - characterName: "\uC11C\uC7A5"
    portrait: 0
    charInterval: 0.05
    choices: {fileID: 0}
    text: "\uADF8\uB7EC\uB2C8\uAE4C...2\uB144\uC804\uC5D0 \uC2E4\uC885\uB41C \uC790\uB124\uC758
      \uBC84\uB514...\uAE30\uC5B5\uD558\uACE0\uC788\uB098?"
  - characterName: "\uC0B0"
    portrait: 0
    charInterval: 0.1
    choices: {fileID: 0}
    text: ...
  - characterName: "\uC11C\uC7A5"
    portrait: 0
    charInterval: 0.1
    choices: {fileID: 0}
    text: "\uADF8\uB140\uB97C \uCC3E\uC558\uB2E4\uB294 \uBCF4\uACE0\uAC00 \uBA87
      \uC2DC\uAC04 \uC804 \uB3C4\uCC29\uD588\uB124"
  - characterName: "\uC0B0"
    portrait: 0
    charInterval: 0.02
    choices: {fileID: 0}
    text: "...\uB85C\uC988\uB294 \uC9C0\uAE08 \uC5B4\uB514\uC788\uC2B5\uB2C8\uAE4C"
  - characterName: "\uC11C\uC7A5"
    portrait: 0
    charInterval: 0.1
    choices: {fileID: 0}
    text: "\uADF8\uB140\uB294 \uC0B4\uD574\uB2F9\uD55C \uCC44\uB85C \uBC1C\uACAC\uB418\uC5C8\uB124"
  - characterName: "\uC0B0"
    portrait: 0
    charInterval: 0.1
    choices: {fileID: 0}
    text: ..............
  - characterName: "\uC0B0"
    portrait: 0
    charInterval: 0.1
